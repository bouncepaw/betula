{{define "title"}}Day {{.DayStamp}}{{end}}
{{define "body"}}
<main class="h-feed">{{$root := .}}
	<article>{{$cnt := len .Bookmarks}}
		<h2 class="p-name"><span class="mv-count">{{$cnt}}</span> bookmark{{if ne $cnt 1}}s{{end}} for {{.DayStamp}}</h2>
	</article>
{{range .Bookmarks}}
	<article class="h-entry" id="{{.ID}}">
	{{if .RemarkOf}}
		<div class="bookmark-remark">
			<div class="actor-link">
				<a href="/@{{$root.AdminUsername}}" class="profile-link">{{$root.AdminUsername}}</a>
			</div>
			remarked
			{{if not .Visibility}}
				<span class="bookmark-visibility" data-visibility="private">Private</span>
			{{end}}
		</div>
	{{end}}
		<div class="bookmark-title">
			<h4 class="p-name"><a class="u-url" href="/go/{{.ID}}">{{.Title}}</a></h4>
			<a class="u-bookmark-of h-cite" href="/go/{{.ID}}">{{shortenLink .URL}}</a>
		</div>

	{{if .RemarkOf}}
		<div class="myco e-content">
			{{if .OriginalAuthor.Valid}}
				<div class="actor-link">{{originalAuthor .OriginalAuthor.String}}</div>
			{{else}}
				<div class="actor-link"><i>Unnamed betulist</i></div>
			{{end}}
			{{.Description}}
		</div>
	{{else}}
		<div class="myco e-content">
			{{if not .Visibility}}
				<span class="bookmark-visibility" data-visibility="private">Private</span>
			{{end}}
			{{mycomarkup .Description}}
		</div>
	{{end}}
	{{if .Tags}}
		<div class="bookmark-tags">
			<span class="tags-marker">#</span>
			{{range $i, $cat := .Tags}}{{if $i}},{{end}}<a class="p-category" href="/tag/{{$cat.Name}}">{{$cat.Name}}</a>{{end}}
		</div>
	{{end}}
		<div class="bookmark-controls">
		{{if $root.Authorized}}
			<button class="btn-control" onclick="copyTextElem({{.URL}}, this)">Copy</button>
			<a class="btn-control" style="margin-left:auto" href="/edit-link/{{.ID}}">Edit</a>
			{{if .RemarkOf}}<a class="btn-control" href="{{.RemarkOf}}">Open original</a>{{end}}
			<a class="btn-control" href="/{{.ID}}">{{.ID}}.</a>
		{{else}}
			<button class="btn-control" onclick="copyTextElem({{.URL}}, this)">Copy</button>
			{{if gt .LikeCounter 0}}{{if .LikeCounter}}{{.LikeCounter}} like{{if ne .LikeCounter 1}}s{{end}}{{end}}{{end}}
			{{if .RemarkOf}}<a class="btn-control" style="margin-left:auto" href="{{.RemarkOf}}">Open original</a>{{end}}
			<a class="btn-control" {{if not .RemarkOf}}style="margin-left:auto"{{end}} href="/{{.ID}}">{{.ID}}.</a>
		{{end}}
		</div>
	</article>
{{- else -}}
	{{if ne .TotalBookmarks 0}}
		<article>Page not found. Choose a page from the paginator below.</article>
	{{end}}
{{end}}
</main>
{{end}}